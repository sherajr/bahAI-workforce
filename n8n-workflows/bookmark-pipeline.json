      "position": [4000, 300],
      "webhookId": "poll-wait-4-hook"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'http://127.0.0.1:8765/pipeline/status/' + $('Start Write Job').item.json.job_id }}",
        "options": {"timeout": 15000}
      },
      "id": "poll-status-4",
      "name": "Poll Status 4 (final)",
      "type": "n8n-nodes-base.httpRequest",
