    {
      "parameters": {
        "jsCode": "const poll = $json;\nif (poll.status === 'error') {\n  throw new Error('Write & Approve job failed: ' + (poll.error || 'unknown error'));\n}\nconst result = poll.result || {};\nreturn [{\n  json: {\n    listing: result.listing || {},\n    review: result.review || {},\n    attempts: result.attempts || 1,\n    target_reached: result.target_reached !== false,\n    consultation: result.consultation || [],\n  }\n}];"
      },
      "id": "extract-wa-result",
      "name": "Extract WA Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4400, 300]
    },
    {
      "parameters": {
        "jsCode": "const theme = $('Receive Bookmark Request').item.json.body.theme;\nconst taskId = $('Build Artist Payload').item.json.task_id;\nconst imageUrl = $('Artist Generate').item.json.image_url;\nconst imagePrompt = $('Artist Brief').item.json.image_prompt;\nconst wa = $('Extract WA Result').item.json;\n\nreturn [{\n  json: {\n    task_id: taskId,\n    theme: theme,\n    image_url: imageUrl,\n    image_prompt: imagePrompt,\n    listing: wa.listing,\n    reviewer_scores: wa.review,\n  }\n}];"
      },
      "id": "build-save-payload",
      "name": "Build Save Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4620, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8765/products/save",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": {}
      },
      "id": "save-product",
      "name": "Save Product",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [4840, 300]
    },
    {
      "parameters": {
        "jsCode": "const imageUrl = $('Artist Generate').item.json.image_url;\nconst quote = $('Extract WA Result').item.json.listing.bookmark_quote || '';\nconst taskId = $('Build Artist Payload').item.json.task_id;\n\nreturn [{\n  json: {\n    image_path: imageUrl,\n    quote: quote,\n    task_id: taskId,\n  }\n}];"
      },
      "id": "build-compositor-payload",
      "name": "Build Compositor Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [5060, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8765/compositor/render",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": {"timeout": 30000}
      },
      "id": "compositor-render",
      "name": "Compositor Render",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [5280, 300]
    },
    {
      "id": "canva-autofill",
      "name": "Canva Autofill",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [5500, 300],
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8765/canva/autofill",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"image_path\": $('Compositor Render').item.json.front_image_path, \"task_id\": $('Build Artist Payload').item.json.task_id } }}",
        "options": {"timeout": 30000}
      }
    },
    {
      "parameters": {
        "jsCode": "const theme = $('Receive Bookmark Request').item.json.body.theme;\nconst imageUrl = $('Artist Generate').item.json.image_url;\nconst frontImagePath = $('Compositor Render').item.json.front_image_path || imageUrl;\nconst backImagePath = $('Compositor Render').item.json.back_image_path || null;\nconst wa = $('Extract WA Result').item.json;\nconst listing = wa.listing;\nconst review = wa.review;\nconst attempts = wa.attempts;\nconst targetReached = wa.target_reached;\nconst consultationTurns = wa.consultation || [];\nconst productId = $('Save Product').item.json.product_id;\nconst taskId = $('Build Artist Payload').item.json.task_id;\n\nconst overall = review.overall || 0;\nconst recommendation = review.recommendation || 'No recommendation';\n\nlet badge;\nif (overall >= 9 && targetReached) {\n  badge = overall >= 9.5 ? 'EXCEPTIONAL' : 'APPROVED';\n} else {\n  badge = 'BEST EFFORT';\n}\n\nconst scores = review.scores || {};\nconst scoreLines = Object.entries(scores).map(([k, v]) =>\n  `  ${k}: ${v.score}/10 — ${v.note}`\n).join('\\n');\n\nconst tags = (listing.tags || []).slice(0, 8).join(', ');\n\nconst attemptsNote = attempts === 1\n  ? 'Approved on first attempt.'\n  : `Reached score after ${attempts} revision${attempts > 1 ? 's' : ''}.`;\n\nconst consultLines = consultationTurns.length > 0\n  ? consultationTurns.flatMap(t => [\n      `[${t.agent} — ${t.role}]`,\n      t.message,\n      '',\n    ])\n  : ['(No consultation recorded)'];\n\nconst summary = [\n  `=== BOOKMARK PIPELINE COMPLETE — ${badge} ===`,\n  '',\n  `Task ID   : ${taskId}`,\n  `Product ID: ${productId}`,\n  `Theme     : ${theme}`,\n  `Score     : ${overall}/10  |  ${attemptsNote}`,\n  '',\n  '--- AGENT CONSULTATION ---',\n  ...consultLines,\n  '--- LISTING ---',\n  `Title     : ${listing.title || '—'}`,\n  `Quote     : ${listing.bookmark_quote || '—'}`,\n  `Price     : ${listing.price_note || '—'}`,\n  `Tags      : ${tags}`,\n  '',\n  '--- IMAGE ---',\n  `Source    : ${imageUrl}`,\n  `Front     : ${frontImagePath}`,\n  `Back      : ${backImagePath || '—'}`,\n  '',\n  '--- REVIEW ---',\n  `Overall   : ${overall}/10`,\n  `Decision  : ${recommendation}`,\n  '',\n  'Principle scores:',\n  scoreLines,\n  '',\n  targetReached\n    ? 'Next step: Review front + back images, then post to Etsy.'\n    : `Note: Could not reach 9.0 after ${attempts} attempts (${overall}/10). Listing saved — review manually before posting.`,\n].join('\\n');\n\nreturn [{\n  json: {\n    task_id: taskId,\n    product_id: productId,\n    theme: theme,\n    image_url: imageUrl,\n    front_image_path: frontImagePath,\n    back_image_path: backImagePath,\n    bookmark_quote: listing.bookmark_quote || null,\n    listing_title: listing.title,\n    listing_tags: listing.tags,\n    listing_description: listing.description,\n    price_note: listing.price_note,\n    review_overall: overall,\n    review_passed: review.passed,\n    review_recommendation: recommendation,\n    badge: badge,\n    attempts: attempts,\n    target_reached: targetReached,\n    consultation: consultationTurns,\n    summary: summary,\n  }\n}];"
      },
      "id": "format-summary",
      "name": "Format Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [5720, 300]
    }
