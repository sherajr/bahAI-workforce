        "url": "http://127.0.0.1:8765/librarian/retrieve",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"text\": \"{{ $('Receive Bookmark Request').item.json.body.theme }}\",\n  \"n_results\": 3\n}",
        "options": {}
      },
      "id": "librarian-retrieve",
      "name": "Librarian Retrieve",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300]
