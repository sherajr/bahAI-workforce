    {
      "parameters": {
        "jsCode": "const taskId = $('Build Artist Payload').item.json.task_id;\nconst imagePrompt = $('Artist Brief').item.json.image_prompt;\n\nreturn [{\n  json: {\n    prompt: imagePrompt,\n    aspect_ratio: '2:3',\n    task_id: taskId,\n  }\n}];"
      },
      "id": "build-generate-payload",
