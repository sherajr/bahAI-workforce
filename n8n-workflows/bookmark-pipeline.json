      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "jsCode": "const theme = $('Receive Bookmark Request').item.json.body.theme;\nconst taskId = $('Build Artist Payload').item.json.task_id;\nconst imagePrompt = $('Artist Brief').item.json.image_prompt;\nconst imageUrl = $('Artist Generate').item.json.image_url;\nconst citations = $('Librarian Retrieve').item.json.passages || [];\n\nreturn [{\n  json: {\n    theme: theme,\n    image_prompt: imagePrompt,\n    image_url: imageUrl,\n    citations: citations,\n    task_id: taskId,\n    target_score: 9.0,\n    max_attempts: 3,\n  }\n}];"
      },
