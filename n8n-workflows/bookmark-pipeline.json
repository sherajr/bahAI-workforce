    {
      "parameters": {
        "jsCode": "const theme = $('Receive Bookmark Request').item.json.body.theme;\nconst taskId = $('Create Task').item.json.task_id;\nconst libResult = $('Librarian Retrieve').item.json;\nconst citations = libResult.passages || [];\n\nreturn [{\n  json: {\n    theme: theme,\n    citations: citations,\n    task_id: taskId,\n  }\n}];"
      },
      "id": "build-artist-payload",
      "name": "Build Artist Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
